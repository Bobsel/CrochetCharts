{
  "name": "CrochetCharts (Qt4)",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--net=host",
    "-e", "DISPLAY=${localEnv:DISPLAY}",
    "-v", "/tmp/.X11-unix:/tmp/.X11-unix"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "twxs.cmake"
      ]
    }
  },
  "postCreateCommand": "mkdir -p /workspaces/CrochetCharts/build"
}
